# Copy this file to .env (used by drizzle-kit CLI and Next.js) and fill in real values.

# Any standard Postgres connection string works (local Postgres, Neon, RDS, etc).
# For Neon (https://neon.tech), use the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js — generate with: npx auth secret
AUTH_SECRET=""

# Set to "true" to enable a dev-only credentials login (no real account needed).
# Must stay unset/false in production. See docs/local-dev.md.
AUTH_DEV_LOGIN_ENABLED="true"

# Microsoft Entra ID app registration (see docs/azure-ad-setup.md).
# Leave unset to run the app with SharePoint/Graph features disabled
# (manual "paste a link" mode still works) and "Sign in with Microsoft" hidden.
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""

# SharePoint list of controller passwords to sync in (see src/lib/graph/lists.ts).
# A "Copy link" share URL for the list, e.g. https://{tenant}.sharepoint.com/:l:/s/{site}/{token}
SHAREPOINT_CONTROLLER_LIST_URL=""
